---
// utils
import { currentYear } from "@utils/currentYear";

// components
import Text from "@elements/Text.astro"
import Link from "@elements/Link.astro"

// change the name here
const {
    name = "Jorge Sánchez"
} = Astro.props;
---

<footer class="flex flex-col gap-16 text-center text-base-600">
    <Text variant={'sm'}>{name} &copy; {currentYear()}</Text>
    <Text variant={'sm'}>Plantilla original de <Link variant={'inline'} href="https://astro.build" text="Astro" newWindow/> por <Link variant={'inline'} href="https://jessgaspar.dev/themes" text="Jess Gaspar" newWindow/></Text>
    // <Text variant={'sm'}>Built with  by <Link variant={'inline'} href="https://jessgaspar.dev/themes" text="Jess Gaspar" newWindow/></Text>
</footer>